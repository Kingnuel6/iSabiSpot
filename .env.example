# .env.example — commit this file, placeholders only
# Copy to .env.local and fill in real values — NEVER commit .env.local

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── OpenRouter (AI processing via Gemini + DeepSeek) ────────────────────────
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# ─── Apify (social media scraping) ───────────────────────────────────────────
# Get your token from https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token

# ─── Cron security ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used to protect /api/scrape, /api/process, and /api/cron routes
CRON_SECRET=your_random_cron_secret
